# ============================================
# FAMILY MONEY TRACKER - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/family_money_tracker?retryWrites=true&w=majority

# JWT Secret Key (use a long random string - minimum 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# JWT Token Expiry
JWT_EXPIRES_IN=30d

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# Admin Credentials (set these ONCE - used for first-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=FamilyTracker@2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
